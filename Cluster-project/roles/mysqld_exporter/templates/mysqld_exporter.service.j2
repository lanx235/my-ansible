[Unit]
Description=MySQL Prometheus Exporter
After=network-online.target

[Service]
User={{ user }}
Group={{ user }}
Type=simple
Restart=on-failure
ExecStart={{ install_path }} \
    --config.my-cnf={{ exporter_cnf }} \
    --web.listen-address=0.0.0.0:{{ exporter_port }}

[Install]
WantedBy=multi-user.target
